# Zukari monorepo gitignore

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Environment / secrets
.env
.env.local
.env.*.local
*.pem
config/jwt/*.pem
**/config/jwt/*.pem

# Node / frontend
node_modules/
dist/
build/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/

# Capacitor / mobile build outputs
android/app/build/
android/.gradle/
android/local.properties
ios/App/Pods/
ios/App/build/
ios/App/App.xcworkspace/
ios/App/Podfile.lock

# Database / dumps
*.sql
*.sqlite
*.sqlite3
*.db
database-dumps/
backups/

# Logs
*.log

# Generated files
*.tmp
*.bak
